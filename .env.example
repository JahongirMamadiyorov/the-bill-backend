PORT=3000
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
JWT_SECRET=your_super_secret_key_here_change_this
JWT_EXPIRES_IN=7d
NODE_ENV=production
CORS_ORIGIN=https://your-app.vercel.app

# PowerSync (Windows POS app, Phase 0) — leave unset until the PowerSync Cloud instance exists.
# POWERSYNC_URL is the instance URL from the PowerSync Dashboard's "Connect" dialog.
# POWERSYNC_JWT_SECRET must be the exact same base64url string entered in PowerSync's
# Client Auth > HS256 Authentication Tokens config, with matching POWERSYNC_KID as the KID.
POWERSYNC_URL=
POWERSYNC_JWT_SECRET=
POWERSYNC_KID=the-bill-ps-key
